# ============================================================================
# IPSSI_APOCAL_KIT — .env de PRODUCTION (MODÈLE, sans secret réel)
# ----------------------------------------------------------------------------
# Sur le VPS :  cp .env.prod.example .env   puis remplir les <...>   puis  chmod 600 .env
# NE JAMAIS committer le .env rempli. Domaine cible : apocalipssi26.elafrit.com
# ============================================================================

# --- Django (PRODUCTION) ---
DJANGO_DEBUG=False
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=<COLLER_UNE_CLE_ALEATOIRE_LONGUE>
# localhost/127.0.0.1 inclus pour le healthcheck interne du conteneur backend.
DJANGO_ALLOWED_HOSTS=apocalipssi26.elafrit.com,localhost,127.0.0.1
# Doit comporter le schéma https:// (POST admin Django / Swagger).
CSRF_TRUSTED_ORIGINS=https://apocalipssi26.elafrit.com
CORS_ALLOWED_ORIGINS=https://apocalipssi26.elafrit.com
FRONTEND_URL=https://apocalipssi26.elafrit.com

# --- PostgreSQL ---
POSTGRES_DB=apocal
POSTGRES_USER=apocal
# Générer : openssl rand -base64 32   (NE PAS laisser apocal-dev-only)
POSTGRES_PASSWORD=<COLLER_UN_MOT_DE_PASSE_FORT>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Frontend (valeur figée AU BUILD de l'image) ---
# Same-origin : l'API est servie par Caddy sous /api -> pas de CORS, pas de
# domaine en dur dans le bundle. Laisser "/api" sauf besoin particulier.
VITE_API_BASE_URL=/api

# --- LLM ---
# Recommandé sur VPS sans GPU : un fournisseur CLOUD (free tier), PAS Ollama.
# Groq (gratuit, ultra-rapide) : https://console.groq.com/keys
LLM_BACKEND=groq
GROQ_API_KEY=<COLLER_VOTRE_CLE_GROQ>
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative européenne : LLM_BACKEND=mistral + MISTRAL_API_KEY=... (https://console.mistral.ai/)
# Ollama local à la place : LLM_BACKEND=ollama, puis démarrer avec `--profile ollama`
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=600

# --- Email (Brevo) ---
# ⚠️ La clé présente dans .env.example est PUBLIQUE/COMPROMISE : ne JAMAIS la
# réutiliser. Laisser vide = emails affichés dans les logs (backend console).
# Pour de vrais envois : créer une NOUVELLE clé SMTP Brevo.
BREVO_SMTP_KEY=
BREVO_SMTP_LOGIN=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
DEFAULT_FROM_EMAIL=EduTutor IA <no-reply@apocalipssi26.elafrit.com>

# --- Reverse proxy externe (optionnel) ---
# Si l'app est déployée DERRIÈRE un reverse proxy existant (ex. un Caddy/nginx qui
# occupe déjà 80/443 sur le VPS), indiquez le nom du réseau Docker de ce proxy :
# scripts/deploy.sh y reconnectera automatiquement les conteneurs après chaque build.
# Laissez VIDE pour un VPS dédié (l'app lance alors son propre Caddy via --profile edge).
# PROXY_NETWORK=formaplanner_formaplanner

# --- Durcissement prod ---
# DJANGO_SECURE_PROD=True est déjà forcé par docker-compose.prod.yml
# (HTTPS redirect, cookies Secure, HSTS, stockage statique à manifeste).
